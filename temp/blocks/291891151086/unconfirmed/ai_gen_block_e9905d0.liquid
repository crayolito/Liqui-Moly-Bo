{% doc %}
  @prompt
    Create a brand-specific navigation section for the WD-40 collection template only.
    Place it below the existing global header.
    Include:
    - WD-40 logo on the left
    - 3 clickable navigation items on the right: Inicio, Productos, Contacto
    - WD-40 colors (blue and yellow)
    - clean horizontal layout
    Important:
    - do not modify the global store header
    - do not change the Liqui Moly header or logo
    - apply this only to the wd40collection template
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wd40-nav-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
  }

  .ai-wd40-nav-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .ai-wd40-nav-logo-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-wd40-nav-logo-{{ ai_gen_id }} img {
    height: {{ block.settings.logo_height }}px;
    width: auto;
    display: block;
  }

  .ai-wd40-nav-logo-placeholder-{{ ai_gen_id }} {
    height: {{ block.settings.logo_height }}px;
    width: 120px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    position: relative;
  }

  .ai-wd40-nav-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-wd40-nav-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: -25px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    color: #999;
    white-space: nowrap;
    pointer-events: none;
  }

  .ai-wd40-nav-menu-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.nav_spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-wd40-nav-item-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-wd40-nav-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.link_padding_vertical }}px {{ block.settings.link_padding_horizontal }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_font_size }}px;
    font-weight: {{ block.settings.link_font_weight }};
    border-radius: {{ block.settings.link_border_radius }}px;
    transition: all 0.3s ease;
    background-color: transparent;
  }

  .ai-wd40-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    background-color: {{ block.settings.link_hover_bg }};
  }

  @media screen and (max-width: 749px) {
    .ai-wd40-nav-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 15px;
    }

    .ai-wd40-nav-menu-{{ ai_gen_id }} {
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
      gap: 10px;
    }

    .ai-wd40-nav-logo-{{ ai_gen_id }} img {
      height: {{ block.settings.logo_height | times: 0.8 }}px;
    }

    .ai-wd40-nav-logo-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-wd40-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-wd40-nav-container-{{ ai_gen_id }}">
    <div class="ai-wd40-nav-logo-{{ ai_gen_id }}">
      {% if block.settings.logo %}
        <img
          src="{{ block.settings.logo | image_url: width: 400 }}"
          alt="{{ block.settings.logo.alt | default: 'WD-40 Logo' | escape }}"
          loading="lazy"
          width="{{ block.settings.logo.width }}"
          height="{{ block.settings.logo.height }}"
        >
      {% else %}
        <div class="ai-wd40-nav-logo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-wd40-nav-empty-state-{{ ai_gen_id }}">
            Add WD-40 logo
          </div>
        </div>
      {% endif %}
    </div>

    <nav>
      <ul class="ai-wd40-nav-menu-{{ ai_gen_id }}">
        {% if block.settings.nav_item_1_text != blank %}
          <li class="ai-wd40-nav-item-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.nav_item_1_url }}"
              class="ai-wd40-nav-link-{{ ai_gen_id }}"
            >
              {{ block.settings.nav_item_1_text }}
            </a>
          </li>
        {% endif %}

        {% if block.settings.nav_item_2_text != blank %}
          <li class="ai-wd40-nav-item-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.nav_item_2_url }}"
              class="ai-wd40-nav-link-{{ ai_gen_id }}"
            >
              {{ block.settings.nav_item_2_text }}
            </a>
          </li>
        {% endif %}

        {% if block.settings.nav_item_3_text != blank %}
          <li class="ai-wd40-nav-item-{{ ai_gen_id }}">
            <a
              href="{{ block.settings.nav_item_3_url }}"
              class="ai-wd40-nav-link-{{ ai_gen_id }}"
            >
              {{ block.settings.nav_item_3_text }}
            </a>
          </li>
        {% endif %}
      </ul>
    </nav>
  </div>
</div>

{% schema %}
{
  "name": "WD-40 brand navigation",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "WD-40 logo"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Logo height",
      "default": 50
    },
    {
      "type": "header",
      "content": "Navigation items"
    },
    {
      "type": "text",
      "id": "nav_item_1_text",
      "label": "Item 1 text",
      "default": "Inicio"
    },
    {
      "type": "url",
      "id": "nav_item_1_url",
      "label": "Item 1 link"
    },
    {
      "type": "text",
      "id": "nav_item_2_text",
      "label": "Item 2 text",
      "default": "Productos"
    },
    {
      "type": "url",
      "id": "nav_item_2_url",
      "label": "Item 2 link"
    },
    {
      "type": "text",
      "id": "nav_item_3_text",
      "label": "Item 3 text",
      "default": "Contacto"
    },
    {
      "type": "url",
      "id": "nav_item_3_url",
      "label": "Item 3 link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0066CC"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#FFD100"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 3
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#FFD100"
    },
    {
      "type": "color",
      "id": "link_hover_bg",
      "label": "Link hover background",
      "default": "#0052A3"
    },
    {
      "type": "range",
      "id": "link_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Link font size",
      "default": 16
    },
    {
      "type": "select",
      "id": "link_font_weight",
      "label": "Link font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Vertical padding",
      "default": 15
    },
    {
      "type": "range",
      "id": "nav_spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Space between items",
      "default": 30
    },
    {
      "type": "range",
      "id": "link_padding_vertical",
      "min": 5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Link vertical padding",
      "default": 8
    },
    {
      "type": "range",
      "id": "link_padding_horizontal",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Link horizontal padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "link_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Link border radius",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "WD-40 brand navigation"
    }
  ]
}
{% endschema %}