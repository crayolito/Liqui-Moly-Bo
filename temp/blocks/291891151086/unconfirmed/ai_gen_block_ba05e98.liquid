{% doc %}
  @prompt
    Create a custom section for the wd40collection template that visually matches the existing Liqui Moly header.
    
    It should include:
    - WD-40 logo on the left
    - search bar in the center
    - phone number and email
    - currency selector
    - account and cart icons
    - a second blue navigation bar below with clickable menu items
    
    Style it to look as close as possible to the current Liqui Moly header layout, spacing, and proportions, but using WD-40 branding.
    
    Important:
    - do not modify the global Shopify header
    - create this only as a custom section inside the wd40collection template
    - keep it fully clickable and editable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .wd40-custom-header-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.header_background }};
    position: relative;
    z-index: 100;
  }

  .wd40-header-top-{{ ai_gen_id }} {
    background-color: {{ block.settings.top_bar_background }};
    padding: {{ block.settings.top_bar_padding }}px 0;
  }

  .wd40-header-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
  }

  .wd40-logo-section-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.logo_width }}px;
  }

  .wd40-logo-section-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .wd40-logo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 60px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .wd40-logo-placeholder-{{ ai_gen_id }} svg {
    width: 50px;
    height: 50px;
    opacity: 0.3;
  }

  .wd40-search-section-{{ ai_gen_id }} {
    flex-grow: 1;
    max-width: 500px;
  }

  .wd40-search-form-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .wd40-search-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 45px 12px 15px;
    border: 1px solid {{ block.settings.search_border_color }};
    border-radius: {{ block.settings.search_border_radius }}px;
    background-color: {{ block.settings.search_background }};
    color: {{ block.settings.search_text_color }};
    font-size: 14px;
  }

  .wd40-search-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.search_placeholder_color }};
  }

  .wd40-search-button-{{ ai_gen_id }} {
    position: absolute;
    right: 5px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
    color: {{ block.settings.search_icon_color }};
  }

  .wd40-search-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .wd40-contact-section-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .wd40-contact-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.contact_text_color }};
    text-decoration: none;
    font-size: 14px;
  }

  .wd40-contact-item-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .wd40-icons-section-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    flex-shrink: 0;
  }

  .wd40-currency-selector-{{ ai_gen_id }} {
    padding: 8px 12px;
    border: 1px solid {{ block.settings.currency_border_color }};
    border-radius: {{ block.settings.currency_border_radius }}px;
    background-color: {{ block.settings.currency_background }};
    color: {{ block.settings.currency_text_color }};
    font-size: 14px;
    cursor: pointer;
  }

  .wd40-icon-link-{{ ai_gen_id }} {
    color: {{ block.settings.icon_color }};
    text-decoration: none;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
  }

  .wd40-icon-link-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .wd40-cart-count-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    right: 0;
    background-color: {{ block.settings.cart_badge_background }};
    color: {{ block.settings.cart_badge_text }};
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: bold;
  }

  .wd40-nav-bar-{{ ai_gen_id }} {
    background-color: {{ block.settings.nav_background }};
    padding: 0;
  }

  .wd40-nav-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .wd40-nav-menu-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .wd40-nav-item-{{ ai_gen_id }} {
    margin: 0;
  }

  .wd40-nav-link-{{ ai_gen_id }} {
    display: block;
    padding: {{ block.settings.nav_link_padding }}px 20px;
    color: {{ block.settings.nav_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.nav_font_size }}px;
    font-weight: {{ block.settings.nav_font_weight }};
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .wd40-nav-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_background }};
    color: {{ block.settings.nav_hover_text_color }};
  }

  @media screen and (max-width: 990px) {
    .wd40-header-container-{{ ai_gen_id }} {
      flex-wrap: wrap;
      gap: 15px;
    }

    .wd40-search-section-{{ ai_gen_id }} {
      order: 3;
      flex-basis: 100%;
      max-width: 100%;
    }

    .wd40-contact-section-{{ ai_gen_id }} {
      display: none;
    }

    .wd40-nav-menu-{{ ai_gen_id }} {
      flex-wrap: wrap;
    }

    .wd40-nav-link-{{ ai_gen_id }} {
      padding: {{ block.settings.nav_link_padding }}px 15px;
      font-size: {{ block.settings.nav_font_size | minus: 1 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .wd40-logo-section-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.7 }}px;
    }

    .wd40-icons-section-{{ ai_gen_id }} {
      gap: 10px;
    }

    .wd40-currency-selector-{{ ai_gen_id }} {
      padding: 6px 10px;
      font-size: 12px;
    }

    .wd40-nav-link-{{ ai_gen_id }} {
      padding: {{ block.settings.nav_link_padding | minus: 2 }}px 12px;
      font-size: {{ block.settings.nav_font_size | minus: 2 }}px;
    }
  }
{% endstyle %}

<wd40-custom-header-{{ ai_gen_id }} class="wd40-custom-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="wd40-header-top-{{ ai_gen_id }}">
    <div class="wd40-header-container-{{ ai_gen_id }}">
      <div class="wd40-logo-section-{{ ai_gen_id }}">
        {% if block.settings.logo %}
          <a href="{{ block.settings.logo_link }}">
            <img
              src="{{ block.settings.logo | image_url: width: 400 }}"
              alt="{{ block.settings.logo.alt | default: shop.name }}"
              width="{{ block.settings.logo.width }}"
              height="{{ block.settings.logo.height }}"
              loading="lazy"
            >
          </a>
        {% else %}
          <div class="wd40-logo-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="wd40-search-section-{{ ai_gen_id }}">
        <form action="/search" method="get" class="wd40-search-form-{{ ai_gen_id }}" role="search">
          <input
            type="search"
            name="q"
            class="wd40-search-input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.search_placeholder }}"
            aria-label="Search"
          >
          <button type="submit" class="wd40-search-button-{{ ai_gen_id }}" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
          </button>
        </form>
      </div>

      <div class="wd40-contact-section-{{ ai_gen_id }}">
        {% if block.settings.phone_number != blank %}
          <a href="tel:{{ block.settings.phone_number }}" class="wd40-contact-item-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span>{{ block.settings.phone_number }}</span>
          </a>
        {% endif %}

        {% if block.settings.email_address != blank %}
          <a href="mailto:{{ block.settings.email_address }}" class="wd40-contact-item-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <span>{{ block.settings.email_address }}</span>
          </a>
        {% endif %}
      </div>

      <div class="wd40-icons-section-{{ ai_gen_id }}">
        {% if block.settings.show_currency_selector %}
          <select class="wd40-currency-selector-{{ ai_gen_id }}" aria-label="Currency selector">
            <option value="BOB">BOB</option>
            <option value="USD">USD</option>
            <option value="EUR">EUR</option>
          </select>
        {% endif %}

        {% if block.settings.show_account_icon %}
          <a href="/account" class="wd40-icon-link-{{ ai_gen_id }}" aria-label="Account">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.show_cart_icon %}
          <a href="/cart" class="wd40-icon-link-{{ ai_gen_id }}" aria-label="Cart">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            <span class="wd40-cart-count-{{ ai_gen_id }}">{{ cart.item_count }}</span>
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  {% if block.settings.show_navigation %}
    <div class="wd40-nav-bar-{{ ai_gen_id }}">
      <div class="wd40-nav-container-{{ ai_gen_id }}">
        <ul class="wd40-nav-menu-{{ ai_gen_id }}">
          {% for i in (1..8) %}
            {% liquid
              assign menu_text_key = 'menu_item_' | append: i | append: '_text'
              assign menu_link_key = 'menu_item_' | append: i | append: '_link'
              assign menu_text = block.settings[menu_text_key]
              assign menu_link = block.settings[menu_link_key]
            %}
            {% if menu_text != blank %}
              <li class="wd40-nav-item-{{ ai_gen_id }}">
                <a href="{{ menu_link }}" class="wd40-nav-link-{{ ai_gen_id }}">
                  {{ menu_text }}
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
  {% endif %}
</wd40-custom-header-{{ ai_gen_id }}>

<script>
  (function() {
    class WD40CustomHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupCurrencySelector();
        this.setupCartUpdate();
      }

      setupCurrencySelector() {
        const currencySelector = this.querySelector('.wd40-currency-selector-{{ ai_gen_id }}');
        if (currencySelector) {
          currencySelector.addEventListener('change', function(e) {
            console.log('Currency changed to:', e.target.value);
          });
        }
      }

      setupCartUpdate() {
        const cartCount = this.querySelector('.wd40-cart-count-{{ ai_gen_id }}');
        if (cartCount) {
          document.addEventListener('cart:updated', function(event) {
            if (event.detail && event.detail.cart) {
              cartCount.textContent = event.detail.cart.item_count;
            }
          });
        }
      }
    }

    customElements.define('wd40-custom-header-{{ ai_gen_id }}', WD40CustomHeader{{ ai_gen_id }});
  })();
</script>

