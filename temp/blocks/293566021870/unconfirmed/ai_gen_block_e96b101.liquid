{% doc %}
  @prompt
    Crea una sección para product page en Shopify (tema Athens) optimizada para conversión.
    
    Debe incluir:
    
    - Imagen del producto a la izquierda
    - A la derecha:
      - Título con enfoque en beneficio (no técnico)
      - Precio
      - Estado de stock
      - Lista de 4 beneficios cortos con íconos tipo check
      - Botón principal "Comprar ahora"
      - Botón secundario "Consultar por WhatsApp"
    
    El diseño debe ser limpio, moderno y alineado a ecommerce automotriz (tipo Liqui Moly).
    
    Debe ser totalmente editable desde el editor de Shopify., necesito que este vinculado al backend de shopify y que se vea los botones de compra, reviews y todo lo demas
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-conversion-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-conversion__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: start;
  }

  .ai-product-conversion__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-product-conversion__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-product-conversion__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-conversion__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-conversion__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-product-conversion__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-product-conversion__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-conversion__stock-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 500;
    width: fit-content;
  }

  .ai-product-conversion__stock--in-stock-{{ ai_gen_id }} {
    background-color: {{ block.settings.stock_in_bg }};
    color: {{ block.settings.stock_in_text_color }};
  }

  .ai-product-conversion__stock--out-stock-{{ ai_gen_id }} {
    background-color: {{ block.settings.stock_out_bg }};
    color: {{ block.settings.stock_out_text_color }};
  }

  .ai-product-conversion__stock-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
  }

  .ai-product-conversion__benefits-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 8px 0;
  }

  .ai-product-conversion__benefit-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-product-conversion__benefit-icon-{{ ai_gen_id }} {
    width: {{ block.settings.benefit_icon_size }}px;
    height: {{ block.settings.benefit_icon_size }}px;
    flex-shrink: 0;
    background-color: {{ block.settings.benefit_icon_bg }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-conversion__benefit-icon-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    stroke: {{ block.settings.benefit_icon_color }};
  }

  .ai-product-conversion__benefit-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-product-conversion__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-product-conversion__variants-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-product-conversion__variant-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-bottom: 4px;
    display: block;
  }

  .ai-product-conversion__variant-select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid {{ block.settings.text_color }}33;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 15px;
    background-color: #ffffff;
    color: {{ block.settings.text_color }};
    cursor: pointer;
  }

  .ai-product-conversion__quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-product-conversion__quantity-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-product-conversion__quantity-input-{{ ai_gen_id }} {
    width: 80px;
    padding: 10px;
    border: 2px solid {{ block.settings.text_color }}33;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 15px;
    text-align: center;
  }

  .ai-product-conversion__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 8px;
  }

  .ai-product-conversion__button-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 32px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.3s ease;
    width: 100%;
  }

  .ai-product-conversion__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text_color }};
    border-color: {{ block.settings.primary_button_bg }};
  }

  .ai-product-conversion__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    border-color: {{ block.settings.primary_button_hover_bg }};
  }

  .ai-product-conversion__button--primary-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-product-conversion__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text_color }};
    border-color: {{ block.settings.secondary_button_border }};
  }

  .ai-product-conversion__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
    border-color: {{ block.settings.secondary_button_hover_border }};
  }

  .ai-product-conversion__button-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
  }

  .ai-product-conversion__reviews-{{ ai_gen_id }} {
    margin-top: 8px;
  }

  @media screen and (max-width: 768px) {
    .ai-product-conversion__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-product-conversion__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<product-conversion-{{ ai_gen_id }}
  class="ai-product-conversion-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-product-conversion__container-{{ ai_gen_id }}">
    <div class="ai-product-conversion__image-wrapper-{{ ai_gen_id }}">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          alt="{{ product.featured_image.alt | escape }}"
          loading="lazy"
          width="{{ product.featured_image.width }}"
          height="{{ product.featured_image.height }}"
          class="ai-product-conversion__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-product-conversion__image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-product-conversion__content-{{ ai_gen_id }}">
      <h1 class="ai-product-conversion__title-{{ ai_gen_id }}">
        {% if block.settings.custom_title != blank %}
          {{ block.settings.custom_title }}
        {% else %}
          {{ product.title }}
        {% endif %}
      </h1>

      {% if block.settings.show_reviews %}
        <div class="ai-product-conversion__reviews-{{ ai_gen_id }}">
          <div class="shopify-product-reviews-badge" data-id="{{ product.id }}"></div>
        </div>
      {% endif %}

      <div class="ai-product-conversion__price-wrapper-{{ ai_gen_id }}">
        <div id="price-{{ ai_gen_id }}">
          {{ product.selected_or_first_available_variant.price | money }}
          {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
            <span style="text-decoration: line-through; opacity: 0.6; margin-left: 12px; font-size: {{ block.settings.price_size | times: 0.85 }}px;">
              {{ product.selected_or_first_available_variant.compare_at_price | money }}
            </span>
          {% endif %}
        </div>
      </div>

      {% if block.settings.show_stock %}
        <div id="stock-{{ ai_gen_id }}">
          {% if product.selected_or_first_available_variant.available %}
            <div class="ai-product-conversion__stock-{{ ai_gen_id }} ai-product-conversion__stock--in-stock-{{ ai_gen_id }}">
              <svg class="ai-product-conversion__stock-icon-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13.3333 4L6 11.3333L2.66667 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ block.settings.stock_available_label }}
            </div>
          {% else %}
            <div class="ai-product-conversion__stock-{{ ai_gen_id }} ai-product-conversion__stock--out-stock-{{ ai_gen_id }}">
              <svg class="ai-product-conversion__stock-icon-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ block.settings.stock_unavailable_label }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="ai-product-conversion__benefits-{{ ai_gen_id }}">
        {% if block.settings.benefit_1 != blank %}
          <div class="ai-product-conversion__benefit-{{ ai_gen_id }}">
            <div class="ai-product-conversion__benefit-icon-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 6L9 17L4 12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="ai-product-conversion__benefit-text-{{ ai_gen_id }}">{{ block.settings.benefit_1 }}</p>
          </div>
        {% endif %}

        {% if block.settings.benefit_2 != blank %}
          <div class="ai-product-conversion__benefit-{{ ai_gen_id }}">
            <div class="ai-product-conversion__benefit-icon-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 6L9 17L4 12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="ai-product-conversion__benefit-text-{{ ai_gen_id }}">{{ block.settings.benefit_2 }}</p>
          </div>
        {% endif %}

        {% if block.settings.benefit_3 != blank %}
          <div class="ai-product-conversion__benefit-{{ ai_gen_id }}">
            <div class="ai-product-conversion__benefit-icon-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 6L9 17L4 12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="ai-product-conversion__benefit-text-{{ ai_gen_id }}">{{ block.settings.benefit_3 }}</p>
          </div>
        {% endif %}

        {% if block.settings.benefit_4 != blank %}
          <div class="ai-product-conversion__benefit-{{ ai_gen_id }}">
            <div class="ai-product-conversion__benefit-icon-{{ ai_gen_id }}">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 6L9 17L4 12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="ai-product-conversion__benefit-text-{{ ai_gen_id }}">{{ block.settings.benefit_4 }}</p>
          </div>
        {% endif %}
      </div>

      <form class="ai-product-conversion__form-{{ ai_gen_id }}" id="product-form-{{ ai_gen_id }}">
        {% unless product.has_only_default_variant %}
          <div class="ai-product-conversion__variants-{{ ai_gen_id }}">
            {% for option in product.options_with_values %}
              <div>
                <label class="ai-product-conversion__variant-label-{{ ai_gen_id }}" for="option-{{ option.position }}-{{ ai_gen_id }}">
                  {{ option.name }}
                </label>
                <select
                  id="option-{{ option.position }}-{{ ai_gen_id }}"
                  name="options[{{ option.name | escape }}]"
                  class="ai-product-conversion__variant-select-{{ ai_gen_id }}"
                  data-option-position="{{ option.position }}"
                >
                  {% for value in option.values %}
                    <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                      {{ value }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% endfor %}
          </div>
        {% endunless %}

        <div class="ai-product-conversion__quantity-{{ ai_gen_id }}">
          <label class="ai-product-conversion__quantity-label-{{ ai_gen_id }}" for="quantity-{{ ai_gen_id }}">
            Cantidad
          </label>
          <input
            type="number"
            id="quantity-{{ ai_gen_id }}"
            name="quantity"
            value="1"
            min="1"
            class="ai-product-conversion__quantity-input-{{ ai_gen_id }}"
          >
        </div>

        <input type="hidden" name="id" id="variant-id-{{ ai_gen_id }}" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="ai-product-conversion__buttons-{{ ai_gen_id }}">
          <button
            type="submit"
            class="ai-product-conversion__button-{{ ai_gen_id }} ai-product-conversion__button--primary-{{ ai_gen_id }}"
            id="add-to-cart-{{ ai_gen_id }}"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
          >
            <svg class="ai-product-conversion__button-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 2L7.17 4H3C1.9 4 1 4.9 1 6V18C1 19.1 1.9 20 3 20H21C22.1 20 23 19.1 23 18V6C23 4.9 22.1 4 21 4H16.83L15 2H9ZM12 7C14.76 7 17 9.24 17 12C17 14.76 14.76 17 12 17C9.24 17 7 14.76 7 12C7 9.24 9.24 7 12 7Z" fill="currentColor"/>
            </svg>
            <span id="button-text-{{ ai_gen_id }}">
              {% if product.selected_or_first_available_variant.available %}
                {{ block.settings.primary_button_label }}
              {% else %}
                Agotado
              {% endif %}
            </span>
          </button>

          {% if block.settings.whatsapp_number != blank %}
            <a
              href="https://wa.me/{{ block.settings.whatsapp_number | replace: '+', '' | replace: ' ', '' }}?text={{ block.settings.whatsapp_message | url_encode }}%20{{ product.url | prepend: request.origin | url_encode }}"
              target="_blank"
              rel="noopener noreferrer"
              class="ai-product-conversion__button-{{ ai_gen_id }} ai-product-conversion__button--secondary-{{ ai_gen_id }}"
            >
              <svg class="ai-product-conversion__button-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              {{ block.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>
      </form>
    </div>
  </div>
</product-conversion-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductConversion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.productData = {{ product | json }};
      }

      connectedCallback() {
        this.form = this.querySelector('#product-form-{{ ai_gen_id }}');
        this.variantSelects = this.querySelectorAll('[data-option-position]');
        this.variantIdInput = this.querySelector('#variant-id-{{ ai_gen_id }}');
        this.addToCartButton = this.querySelector('#add-to-cart-{{ ai_gen_id }}');
        this.buttonText = this.querySelector('#button-text-{{ ai_gen_id }}');
        this.priceElement = this.querySelector('#price-{{ ai_gen_id }}');
        this.stockElement = this.querySelector('#stock-{{ ai_gen_id }}');

        this.variantSelects.forEach(select => {
          select.addEventListener('change', this.handleVariantChange.bind(this));
        });

        this.form.addEventListener('submit', this.handleSubmit.bind(this));
      }

      handleVariantChange() {
        const selectedOptions = Array.from(this.variantSelects).map(select => select.value);
        const variant = this.productData.variants.find(v => {
          return selectedOptions.every((option, index) => v.options[index] === option);
        });

        if (variant) {
          this.updateVariant(variant);
        }
      }

      updateVariant(variant) {
        this.variantIdInput.value = variant.id;

        const priceHTML = this.formatMoney(variant.price);
        let compareHTML = '';
        if (variant.compare_at_price && variant.compare_at_price > variant.price) {
          compareHTML = `<span style="text-decoration: line-through; opacity: 0.6; margin-left: 12px; font-size: {{ block.settings.price_size | times: 0.85 }}px;">${this.formatMoney(variant.compare_at_price)}</span>`;
        }
        this.priceElement.innerHTML = priceHTML + compareHTML;

        if (variant.available) {
          this.addToCartButton.disabled = false;
          this.buttonText.textContent = '{{ block.settings.primary_button_label }}';
          if (this.stockElement) {
            this.stockElement.innerHTML = `
              <div class="ai-product-conversion__stock-{{ ai_gen_id }} ai-product-conversion__stock--in-stock-{{ ai_gen_id }}">
                <svg class="ai-product-conversion__stock-icon-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M13.3333 4L6 11.3333L2.66667 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {{ block.settings.stock_available_label }}
              </div>
            `;
          }
        } else {
          this.addToCartButton.disabled = true;
          this.buttonText.textContent = 'Agotado';
          if (this.stockElement) {
            this.stockElement.innerHTML = `
              <div class="ai-product-conversion__stock-{{ ai_gen_id }} ai-product-conversion__stock--out-stock-{{ ai_gen_id }}">
                <svg class="ai-product-conversion__stock-icon-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {{ block.settings.stock_unavailable_label }}
              </div>
            `;
          }
        }
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return '{{ cart.currency.symbol }}' + amount.toFixed(2);
      }

      handleSubmit(event) {
        event.preventDefault();

        const formData = new FormData(this.form);
        const data = {
          id: formData.get('id'),
          quantity: formData.get('quantity')
        };

        this.buttonText.textContent = 'Agregando...';
        this.addToCartButton.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(data => {
          window.location.href = '/cart';
        })
        .catch(error => {
          console.error('Error:', error);
          this.buttonText.textContent = '{{ block.settings.primary_button_label }}';
          this.addToCartButton.disabled = false;
          alert('Error al agregar al carrito. Por favor intenta de nuevo.');
        });
      }
    }

    customElements.define('product-conversion-{{ ai_gen_id }}', ProductConversion{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Conversión de producto",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "custom_title",
      "label": "Título personalizado",
      "info": "Deja vacío para usar el título del producto"
    },
    {
      "type": "checkbox",
      "id": "show_stock",
      "label": "Mostrar estado de stock",
      "default": true
    },
    {
      "type": "text",
      "id": "stock_available_label",
      "label": "Etiqueta disponible",
      "default": "Disponible ahora"
    },
    {
      "type": "text",
      "id": "stock_unavailable_label",
      "label": "Etiqueta agotado",
      "default": "Agotado"
    },
