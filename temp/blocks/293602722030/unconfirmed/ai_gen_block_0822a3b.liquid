{% doc %}
  @prompt
    Crea una sección de product page para Shopify compatible con el tema Athens.
    
    IMPORTANTE:
    - Debe usar datos dinámicos del producto (product object)
    - NO usar contenido hardcodeado
    - Debe conectarse completamente con el backend de Shopify
    
    Debe incluir:
    
    IMAGEN:
    - Imagen principal del producto dinámica
    - Galería de imágenes debajo (thumbnails clickeables)
    - Cambio de imagen al hacer click
    - Soporte para múltiples imágenes del producto
    
    INFORMACIÓN:
    - Título dinámico del producto
    - Precio dinámico (incluyendo variantes)
    - Estado de stock dinámico
    - Selector de variantes si aplica
    
    CONTENIDO:
    - Lista de beneficios editable como bloque (no hardcodeado)
    
    ACCIONES:
    - Botón “Agregar al carrito” funcional
    - Botón “Comprar ahora”
    - Botón de WhatsApp con producto dinámico
    
    Debe ser 100% funcional y conectado al backend de Shopify., corregi los errores, Corrige el bloque Liquid de esta product page.
    
    Hay un error porque se está usando un form inválido. 
    En Shopify el form debe usar un tipo válido, y para product page debe ser:
    
    {% form 'product', product %}
    
    o equivalente con product_form_id.
    
    No uses block.id ni ningún identificador dinámico como tipo de form.
    
    Mantén todo conectado al backend de Shopify:
    - producto dinámico
    - precio
    - variantes
    - stock
    - imagen principal
    - thumbnails debajo de la imagen principal
    - botón agregar al carrito funcional
    
    Compatible con tema Athens.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-page-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-product-page-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }

  .ai-product-media-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-product-main-image-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    border: 1px solid #dfdfdf;
  }

  .ai-product-main-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-thumbnails-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 12px;
  }

  .ai-product-thumbnail-{{ ai_gen_id }} {
    border: 2px solid transparent;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.3s ease;
  }

  .ai-product-thumbnail-{{ ai_gen_id }}:hover,
  .ai-product-thumbnail-{{ ai_gen_id }}.active {
    border-color: #004f9d;
  }

  .ai-product-thumbnail-{{ ai_gen_id }} img {
    width: 100%;
    height: 80px;
    object-fit: cover;
    display: block;
  }

  .ai-product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font }};
    font-size: {{ block.settings.title_size }}px;
    color: #232323;
    margin: 0;
    line-height: 1.2;
  }

  .ai-product-price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: {{ block.settings.price_size }}px;
    font-weight: 500;
  }

  .ai-product-price-regular-{{ ai_gen_id }} {
    color: #232323;
  }

  .ai-product-price-compare-{{ ai_gen_id }} {
    color: #676767;
    text-decoration: line-through;
  }

  .ai-product-price-sale-{{ ai_gen_id }} {
    color: #e21919;
  }

  .ai-product-stock-{{ ai_gen_id }} {
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 500;
    display: inline-block;
    width: fit-content;
  }

  .ai-product-stock-instock-{{ ai_gen_id }} {
    background-color: #337239;
    color: #ffffff;
  }

  .ai-product-stock-outofstock-{{ ai_gen_id }} {
    background-color: #922C2C;
    color: #ffffff;
  }

  .ai-product-variants-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-product-variant-label-{{ ai_gen_id }} {
    font-weight: 500;
    color: #232323;
    margin-bottom: 8px;
  }

  .ai-product-variant-select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #dfdfdf;
    border-radius: 4px;
    background-color: #ffffff;
    color: #676767;
    font-size: 16px;
  }

  .ai-product-benefits-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-product-benefit-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .ai-product-benefit-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: {{ block.settings.benefit_icon_color }};
  }

  .ai-product-benefit-text-{{ ai_gen_id }} {
    color: #676767;
    font-size: 16px;
    line-height: 1.5;
  }

  .ai-product-actions-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-product-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-product-quantity-label-{{ ai_gen_id }} {
    font-weight: 500;
    color: #232323;
  }

  .ai-product-quantity-input-{{ ai_gen_id }} {
    width: 80px;
    padding: 12px;
    border: 1px solid #dfdfdf;
    border-radius: 4px;
    text-align: center;
    font-size: 16px;
  }

  .ai-product-button-{{ ai_gen_id }} {
    padding: 16px 32px;
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
    display: inline-block;
  }

  .ai-product-button-primary-{{ ai_gen_id }} {
    background-color: #004f9d;
    color: #ffffff;
  }

  .ai-product-button-primary-{{ ai_gen_id }}:hover {
    background-color: #003d7a;
  }

  .ai-product-button-primary-{{ ai_gen_id }}:disabled {
    background-color: #cccccc;
    cursor: not-allowed;
  }

  .ai-product-button-secondary-{{ ai_gen_id }} {
    background-color: #ffffff;
    color: #004f9d;
    border: 2px solid #004f9d;
  }

  .ai-product-button-secondary-{{ ai_gen_id }}:hover {
    background-color: #f8f8f8;
  }

  .ai-product-button-secondary-{{ ai_gen_id }}:disabled {
    background-color: #f4f4f4;
    color: #cccccc;
    border-color: #cccccc;
    cursor: not-allowed;
  }

  .ai-product-button-whatsapp-{{ ai_gen_id }} {
    background-color: #25D366;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .ai-product-button-whatsapp-{{ ai_gen_id }}:hover {
    background-color: #1fb855;
  }

  .ai-product-whatsapp-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 768px) {
    .ai-product-page-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-product-thumbnails-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
    }

    .ai-product-thumbnail-{{ ai_gen_id }} img {
      height: 60px;
    }
  }
{% endstyle %}

<product-page-{{ ai_gen_id }} class="ai-product-page-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-page-container-{{ ai_gen_id }}">
    <div class="ai-product-media-{{ ai_gen_id }}">
      <div class="ai-product-main-image-{{ ai_gen_id }}" id="ai-main-image-{{ ai_gen_id }}">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | escape }}"
            width="800"
            height="800"
            loading="eager"
          >
        {% else %}
          <div style="background-color: #f4f4f4; aspect-ratio: 1; display: flex; align-items: center; justify-content: center;">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      {% if product.images.size > 1 %}
        <div class="ai-product-thumbnails-{{ ai_gen_id }}">
          {% for image in product.images %}
            <div class="ai-product-thumbnail-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-image-url="{{ image | image_url: width: 800 }}" data-image-alt="{{ image.alt | escape }}">
              <img
                src="{{ image | image_url: width: 100 }}"
                alt="{{ image.alt | escape }}"
                width="100"
                height="100"
                loading="lazy"
              >
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="ai-product-info-{{ ai_gen_id }}">
      <h1 class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</h1>

      <div class="ai-product-price-{{ ai_gen_id }}">
        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <span class="ai-product-price-sale-{{ ai_gen_id }}">{{ product.selected_or_first_available_variant.price | money }}</span>
          <span class="ai-product-price-compare-{{ ai_gen_id }}">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
        {% else %}
          <span class="ai-product-price-regular-{{ ai_gen_id }}">{{ product.selected_or_first_available_variant.price | money }}</span>
        {% endif %}
      </div>

      {% if product.available %}
        <div class="ai-product-stock-{{ ai_gen_id }} ai-product-stock-instock-{{ ai_gen_id }}">
          En stock
        </div>
      {% else %}
        <div class="ai-product-stock-{{ ai_gen_id }} ai-product-stock-outofstock-{{ ai_gen_id }}">
          Agotado
        </div>
      {% endif %}

      {% form 'product', product %}
        {% if product.has_only_default_variant %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% else %}
          <div class="ai-product-variants-{{ ai_gen_id }}">
            {% for option in product.options_with_values %}
              <div>
                <label class="ai-product-variant-label-{{ ai_gen_id }}" for="ai-option-{{ ai_gen_id }}-{{ option.position }}">
                  {{ option.name }}
                </label>
                <select
                  class="ai-product-variant-select-{{ ai_gen_id }}"
                  id="ai-option-{{ ai_gen_id }}-{{ option.position }}"
                  name="options[{{ option.name | escape }}]"
                  data-option-position="{{ option.position }}"
                >
                  {% for value in option.values %}
                    <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                      {{ value }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% endfor %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="ai-variant-id-{{ ai_gen_id }}">
          </div>
        {% endif %}

        {% if block.settings.show_benefits %}
          <div class="ai-product-benefits-{{ ai_gen_id }}">
            {% if block.settings.benefit_1 != blank %}
              <div class="ai-product-benefit-item-{{ ai_gen_id }}">
                <svg class="ai-product-benefit-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="ai-product-benefit-text-{{ ai_gen_id }}">{{ block.settings.benefit_1 }}</span>
              </div>
            {% endif %}
            {% if block.settings.benefit_2 != blank %}
              <div class="ai-product-benefit-item-{{ ai_gen_id }}">
                <svg class="ai-product-benefit-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="ai-product-benefit-text-{{ ai_gen_id }}">{{ block.settings.benefit_2 }}</span>
              </div>
            {% endif %}
            {% if block.settings.benefit_3 != blank %}
              <div class="ai-product-benefit-item-{{ ai_gen_id }}">
                <svg class="ai-product-benefit-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="ai-product-benefit-text-{{ ai_gen_id }}">{{ block.settings.benefit_3 }}</span>
              </div>
            {% endif %}
            {% if block.settings.benefit_4 != blank %}
              <div class="ai-product-benefit-item-{{ ai_gen_id }}">
                <svg class="ai-product-benefit-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="ai-product-benefit-text-{{ ai_gen_id }}">{{ block.settings.benefit_4 }}</span>
              </div>
            {% endif %}
          </div>
        {% endif %}

        <div class="ai-product-actions-{{ ai_gen_id }}">
          <div class="ai-product-quantity-{{ ai_gen_id }}">
            <label class="ai-product-quantity-label-{{ ai_gen_id }}" for="ai-quantity-{{ ai_gen_id }}">Cantidad:</label>
            <input
              type="number"
              class="ai-product-quantity-input-{{ ai_gen_id }}"
              id="ai-quantity-{{ ai_gen_id }}"
              name="quantity"
              value="1"
              min="1"
            >
          </div>

          <button
            type="submit"
            class="ai-product-button-{{ ai_gen_id }} ai-product-button-primary-{{ ai_gen_id }}"
            {% unless product.available %}disabled{% endunless %}
          >
            {% if product.available %}
              Agregar al carrito
            {% else %}
              Agotado
            {% endif %}
          </button>

          {% if block.settings.show_buy_now %}
            <button
              type="submit"
              name="checkout"
              class="ai-product-button-{{ ai_gen_id }} ai-product-button-secondary-{{ ai_gen_id }}"
              {% unless product.available %}disabled{% endunless %}
            >
              Comprar ahora
            </button>
          {% endif %}
        </div>
      {% endform %}

      {% if block.settings.show_whatsapp and block.settings.whatsapp_number != blank %}
        <a
          href="https://wa.me/{{ block.settings.whatsapp_number | replace: '+', '' | replace: ' ', '' }}?text=Hola,%20estoy%20interesado%20en%20{{ product.title | url_encode }}%20-%20{{ shop.url }}{{ product.url }}"
          target="_blank"
          rel="noopener noreferrer"
          class="ai-product-button-{{ ai_gen_id }} ai-product-button-whatsapp-{{ ai_gen_id }}"
        >
          <svg class="ai-product-whatsapp-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Consultar por WhatsApp
        </a>
      {% endif %}
    </div>
  </div>
</product-page-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductPage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.mainImage = null;
        this.thumbnails = null;
        this.variantSelects = null;
        this.variantIdInput = null;
      }

      connectedCallback() {
        this.mainImage = this.querySelector('#ai-main-image-{{ ai_gen_id }} img');
        this.thumbnails = this.querySelectorAll('.ai-product-thumbnail-{{ ai_gen_id }}');
        this.variantSelects = this.querySelectorAll('.ai-product-variant-select-{{ ai_gen_id }}');
        this.variantIdInput = this.querySelector('#ai-variant-id-{{ ai_gen_id }}');
        
        this.setupThumbnails();
        this.setupVariantSelectors();
      }

      setupThumbnails() {
        if (!this.thumbnails) return;
        
        this.thumbnails.forEach((thumbnail) => {
          thumbnail.addEventListener('click', () => {
            const imageUrl = thumbnail.getAttribute('data-image-url');
            const imageAlt = thumbnail.getAttribute('data-image-alt');
            
            if (this.mainImage) {
              this.mainImage.src = imageUrl;
              this.mainImage.alt = imageAlt;
            }

            this.thumbnails.forEach((t) => t.classList.remove('active'));
            thumbnail.classList.add('active');
          });
        });
      }

      setupVariantSelectors() {
        if (!this.variantSelects || this.variantSelects.length === 0) return;

        this.variantSelects.forEach((select) => {
          select.addEventListener('change', () => {
            this.updateVariant();
          });
        });
      }

      updateVariant() {
        const selectedOptions = Array.from(this.variantSelects).map((select) => select.value);
        
        const productData = {{ product | json }};
        const matchedVariant = productData.variants.find((variant) => {
          return variant.options.every((option, index) => option === selectedOptions[index]);
        });

        if (matchedVariant && this.variantIdInput) {
          this.variantIdInput.value = matchedVariant.id;

          const priceElement = this.querySelector('.ai-product-price-{{ ai_gen_id }}');
          if (priceElement) {
            let priceHTML = '';
            if (matchedVariant.compare_at_price && matchedVariant.compare_at_price > matchedVariant.price) {
              priceHTML = '<span class="ai-product-price-sale-{{ ai_gen_id }}">' + this.formatMoney(matchedVariant.price) + '</span><span class="ai-product-price-compare-{{ ai_gen_id }}">' + this.formatMoney(matchedVariant.compare_at_price) + '</span>';
            } else {
              priceHTML = '<span class="ai-product-price-regular-{{ ai_gen_id }}">' + this.formatMoney(matchedVariant.price) + '</span>';
            }
            priceElement.innerHTML = priceHTML;
          }

          const stockElement = this.querySelector('.ai-product-stock-{{ ai_gen_id }}');
          const addToCartButton = this.querySelector('button[type="submit"]:not([name="checkout"])');
          const buyNowButton = this.querySelector('button[name="checkout"]');

          if (matchedVariant.available) {
            if (stockElement) {
              stockElement.className = 'ai-product-stock-{{ ai_gen_id }} ai-product-stock-instock-{{ ai_gen_id }}';
              stockElement.textContent = 'En stock';
            }
            if (addToCartButton) {
              addToCartButton.disabled = false;
              addToCartButton.textContent = 'Agregar al carrito';
            }
            if (buyNowButton) {
              buyNowButton.disabled = false;
            }
          } else {
            if (stockElement) {
              stockElement.className = 'ai-product-stock-{{ ai_gen_id }} ai-product-stock-outofstock-{{ ai_gen_id }}';
              stockElement.textContent = 'Agotado';
            }
            if (addToCartButton) {
              addToCartButton.disabled = true;
              addToCartButton.textContent = 'Agotado';
            }
            if (buyNowButton) {
              buyNowButton.disabled = true;
            }
          }

          if (matchedVariant.featured_image && this.mainImage) {
            const imageUrl = matchedVariant.featured_image.src;
            this.mainImage.src = imageUrl;
            this.mainImage.alt = matchedVariant.featured_image.alt || '';
          }
        }
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return 'Bs ' + amount.toFixed(2);
      }
    }

    customElements.define('product-page-{{ ai_gen_id }}', ProductPage{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Página de producto",
  "tag": null,
  "class": "product-page-block",
  "settings": [
    {
      "type": "header",
      "content": "Estilo del título"
    },
    {
      "type": "select",
      "id": "title_font",
      "label": "Fuente del título",
      "options": [
        {
          "value": "var(--font-heading-family)",
          "label": "Encabezados"
        },
        {
          "value": "var(--font-body-family)",
          "label": "Cuerpo"
        }
      ],
      "default": "var(--font-heading-family)"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño del título",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Tamaño del precio",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Imágenes"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Radio de borde",
      "min": 0,
      "max": 20,
